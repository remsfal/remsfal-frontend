{
  "name": "@remsfal/remsfal-frontend",
  "version": "0.0.10-SNAPSHOT",
  "type": "module",
  "homepage": "https://remsfal.de",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/remsfal/remsfal-frontend.git"
  },
  "bugs": {
    "url": "https://github.com/remsfal/remsfal-frontend/issues"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "scripts": {
    "dev": "vite",
    "build": "run-s type-check \"build-only {@}\" --",
    "build-only": "vite build",
    "type-check": "vue-tsc --build --force",
    "preview": "vite preview",
    "test": "run-s type-check test:unit test:e2e",
    "test:unit": "vitest run",
    "test:unit:dev": "vitest",
    "test:e2e": "start-server-and-test preview http://localhost:4173 'cypress run --e2e'",
    "test:e2e:dev": "start-server-and-test 'vite dev --port 4173' http://localhost:4173 'cypress open --e2e'",
    "cypress": "cypress open",
    "cypress:dev": "run-s test:e2e:dev",
    "coverage": "run-s coverage:clean coverage:unit coverage:e2e coverage:merge",
    "coverage:clean": "rm -rf coverage coverage-vitest coverage-cypress .nyc_output .nyc_input .nyc_report",
    "coverage:unit": "vitest run --coverage",
    "coverage:e2e": "start-server-and-test 'vite dev --port 4173' http://localhost:4173 'cypress run --e2e'",
    "coverage:merge": "node scripts/merge-coverage.js",
    "lint": "eslint --quiet",
    "lint:report": "mkdir -p reports && eslint --format json --output-file reports/eslint-report.json",
    "lint:fix": "eslint --fix",
    "stylelint": "stylelint '{src,public}/**/*.{vue,css,scss}'",
    "stylelint:fix": "stylelint --fix '{src,public}/**/*.{vue,css,scss}'",
    "openapi": "run-p openapi:ticketing openapi:platform openapi:notification",
    "openapi:ticketing": "openapi-typescript openapi/ticketing-spec.json -o src/services/api/ticketing-schema.ts",
    "openapi:platform": "openapi-typescript openapi/platform-spec.json -o src/services/api/platform-schema.ts",
    "openapi:notification": "openapi-typescript openapi/notification-spec.json -o src/services/api/notification-schema.ts"
  },
  "dependencies": {
    "@capacitor/android": "^8.2.0",
    "@capacitor/camera": "^8.2.1",
    "@capacitor/core": "^8.4.2",
    "@capacitor/ios": "^8.4.1",
    "@fortawesome/fontawesome-svg-core": "^7.3.1",
    "@fortawesome/free-regular-svg-icons": "^7.3.1",
    "@fortawesome/free-solid-svg-icons": "^7.3.1",
    "@fortawesome/vue-fontawesome": "^3.3.2",
    "@primevue/forms": ">=4.5.5 <5.0.0",
    "@primevue/themes": ">=4.5.4 <5.0.0",
    "axios": "^1.18.1",
    "chart.js": "^4.5.1",
    "chartjs-plugin-datalabels": "^2.2.0",
    "idb": "^8.0.3",
    "pinia": "^3.0.4",
    "primeicons": "^8.0.0",
    "primevue": ">=4.5.5 <5.0.0",
    "vue": "^3.5.39",
    "vue-i18n": "^11.4.7",
    "vue-router": "^5.0.4",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.2.0",
    "@cypress/code-coverage": "^4.0.3",
    "@intlify/eslint-plugin-vue-i18n": "^4.5.0",
    "@pinia/testing": "^1.0.3",
    "@primevue/auto-import-resolver": ">=4.5.5 <5.0.0",
    "@stylistic/eslint-plugin": "^5.7.1",
    "@tailwindcss/postcss": "^4.3.0",
    "@tsconfig/node-lts": "^24.0.0",
    "@types/jsdom": "^28.0.3",
    "@types/node": "^26.0.1",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vitest/coverage-istanbul": "^4.1.10",
    "@vue/test-utils": "^2.4.11",
    "@vue/tsconfig": "^0.9.1",
    "autoprefixer": "^10.5.4",
    "baseline-browser-mapping": "^2.10.12",
    "chai": "^6.2.2",
    "cypress": "^15.16.0",
    "eslint": "^9.39.2",
    "eslint-import-resolver-typescript": "^4.4.5",
    "eslint-plugin-cypress": "^6.2.0",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-vue": "^10.8.0",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "msw": "^2.14.6",
    "npm-run-all2": "^9.0.2",
    "nyc": "^18.0.0",
    "openapi-typescript": "^7.10.1",
    "postcss": "^8.5.20",
    "sass": "^1.101.0",
    "start-server-and-test": "^2.1.5",
    "stylelint": "^17.11.0",
    "stylelint-config-recommended-vue": "^1.6.1",
    "stylelint-config-standard": "^40.0.0",
    "tailwindcss": "^4.3.1",
    "tailwindcss-primeui": "^0.6.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.64.0",
    "unplugin-vue-components": "^31.0.0",
    "vite": "^8.0.16",
    "vite-plugin-istanbul": "^9.0.1",
    "vite-plugin-pwa": "^1.3.0",
    "vite-plugin-vue-devtools": "^8.1.5",
    "vitest": "^4.1.9",
    "vue-eslint-parser": "^10.4.0",
    "vue-i18n-extract": "^2.0.7",
    "vue-tsc": "^3.2.5",
    "workbox-build": "^7.4.1",
    "workbox-window": "^7.4.1"
  },
  "overrides": {
    "glob": "^13.0.6"
  },
  "allowScripts": {
    "@parcel/watcher@2.5.1": true,
    "unrs-resolver@1.12.2": true,
    "cypress@15.16.0": true,
    "fsevents@2.3.3": true,
    "msw@2.14.6": true
  }
}
