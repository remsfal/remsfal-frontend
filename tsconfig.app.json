{
  "extends": "@vue/tsconfig/tsconfig.dom.json",
  "include": ["env.d.ts", "src/**/*", "src/**/*.vue"],
  "exclude": ["src/**/__tests__/**", "src/sw.ts", "src/types/sw-global.d.ts"],
  "compilerOptions": {
    "composite": true,
    "noEmit": true,
    "baseUrl": ".",
    "lib": ["dom", "es2023"],
    "types": ["vue-router/unplugin"],
    "paths": {
      "@/*": ["./src/*"]
    }
  }
}
